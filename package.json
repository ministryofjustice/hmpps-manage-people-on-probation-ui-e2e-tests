{
  "name": "hmpps-manage-people-on-probation-ui-e2e-tests",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "clean": "rm -rf node_modules .features-gen",
    "clean:feature": "rm -rf .features-gen",
    "rebuild": "npm run clean && npm ci && npx playwright install && npx bddgen",
    "test": "npm run clean:feature  && npx bddgen && npx playwright test",
    "lint": "eslint . --cache --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc",
    "bdd": "cucumber-js",
    "bdd:tags": "cucumber-js --tags",
    "bdd:headed": "HEADLESS=false cucumber-js",
    "bdd:debug": "npx cucumber-js --profile debug",
    "perf:run": "gatling run --typescript",
    "perf:home": "gatling run --typescript --sources-folder src/performance --simulation mpop",
    "prepare": "husky",
    "setup": "npm ci && hmpps-npm-script-run-allowlist"
  },
  "engines": {
    "node": "^24",
    "npm": "^11"
  },
  "keywords": [],
  "author": "",
  "type": "module",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.4.0",
    "@gatling.io/cli": "^3.15.2",
    "@ministryofjustice/hmpps-npm-script-allowlist": "0.0.4",
    "@ministryofjustice/hmpps-probation-integration-e2e-tests": "^1.197.0",
    "@playwright/test": "^1.59.1",
    "@types/luxon": "^3.7.1",
    "@types/node": "^22.19.17",
    "@typescript-eslint/eslint-plugin": "^8.59.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.5.0",
    "husky": "^9.1.7",
    "luxon": "^3.7.2",
    "playwright-bdd": "^8.5.0",
    "prettier": "^3.8.3",
    "tsx": "^4.21.0"
  },
  "dependencies": {
    "@gatling.io/core": "^3.15.2",
    "@gatling.io/http": "^3.15.2",
    "op": "^0.0.6"
  }
}
