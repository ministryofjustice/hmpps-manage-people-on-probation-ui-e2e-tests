{
  "name": "hmpps-manage-people-on-probation-ui-e2e-tests",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "prepare": "hmpps-precommit-hooks-prepare",
    "clean": "rm -rf node_modules .features-gen",
    "clean:feature": "rm -rf .features-gen",
    "rebuild": "npm run clean && npm ci && npx playwright install && npx bddgen",
    "test": "npm run clean:feature && npx bddgen && npx playwright test --grep \"@full\"",
    "lint": "eslint . --cache --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc",
    "bdd": "cucumber-js",
    "bdd:tags": "cucumber-js --tags",
    "bdd:headed": "HEADLESS=false cucumber-js",
    "bdd:debug": "npx cucumber-js --profile debug",
    "perf:run": "gatling run --typescript",
    "perf:home": "gatling run --typescript --sources-folder src/performance --simulation mpop",
    "setup": "npm ci && hmpps-npm-script-run-allowlist"
  },
  "engines": {
    "node": "^24",
    "npm": "^11"
  },
  "keywords": [],
  "author": "",
  "type": "module",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/eslintrc": "^3.3.6",
    "@eslint/js": "^10.0.1",
    "@faker-js/faker": "^10.5.0",
    "@gatling.io/cli": "^3.15.103",
    "@ministryofjustice/hmpps-npm-script-allowlist": "0.0.6",
    "@ministryofjustice/hmpps-probation-integration-e2e-tests": "1.245.0",
    "@playwright/test": "1.61.1",
    "@types/luxon": "^3.7.2",
    "@types/node": "^22.20.1",
    "@typescript-eslint/eslint-plugin": "^8.64.0",
    "dotenv": "^17.4.2",
    "eslint": "^10.7.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.6",
    "globals": "^17.7.0",
    "husky": "^9.1.7",
    "luxon": "^3.7.2",
    "playwright-bdd": "9.2.0",
    "playwright-core": "1.61.1",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1"
  },
  "dependencies": {
    "@gatling.io/core": "^3.15.103",
    "@gatling.io/http": "^3.15.103",
    "@ministryofjustice/hmpps-precommit-hooks": "3.0.1",
    "date-fns": "4.4.0",
    "op": "^0.0.6"
  }
}
