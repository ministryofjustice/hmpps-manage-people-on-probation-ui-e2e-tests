{
  "compilerOptions": {
    "target": "es2023",
    "module": "esnext",
    "moduleResolution": "bundler",
    "allowSyntheticDefaultImports": true,
    "esModuleInterop": true,
    "outDir": "./dist",
    "declaration": true,
    "sourceMap": true,
    "typeRoots": ["./node_modules/@types"],
    "types": ["node"],
    "rootDir": "./src"
  },
  "include": ["src/test", "src/performance"]
}
